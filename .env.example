# ============================
# SEODirect Tool — .env config
# ============================

# Super Admin (задаётся один раз, не менять через веб)
SUPER_ADMIN_LOGIN=admin
SUPER_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
SUPER_ADMIN_EMAIL=admin@company.ru

# База данных (обязательно сменить пароль!)
DATABASE_URL=postgresql+psycopg://seodirect:CHANGE_ME_STRONG_PASSWORD@postgres:5432/seodirect
POSTGRES_USER=seodirect
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=seodirect

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# Безопасность (сгенерировать случайные строки)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
# python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING

# JWT настройки
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_TOKEN_REMEMBER_DAYS=90

# Rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Парсер
CRAWL_DELAY_MS_DEFAULT=1000
CRAWL_TIMEOUT_SECONDS=10
CRAWL_MAX_PAGES=500
CRAWL_USER_AGENT=SEODirectBot/1.0 (internal)
CRAWL_RESPECT_ROBOTS=true

# Приложение
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
FRONTEND_URL=https://yourdomain.ru

# API ключи (можно задать здесь или через веб-настройки)
ANTHROPIC_API_KEY=sk-ant-...
WORDSTAT_OAUTH_TOKEN=
TOPVISOR_API_KEY=
METRIKA_OAUTH_TOKEN=
DIRECT_OAUTH_TOKEN=
DIRECT_CLIENT_LOGIN=
