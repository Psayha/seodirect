# ============================================================
# SEODirect Tool — конфигурация окружения
# Скопируй в .env и заполни значения
# ============================================================

# ── Super Admin (создаётся при первом запуске) ──────────────
SUPER_ADMIN_LOGIN=admin
# Генерация хэша: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('ваш_пароль'))"
SUPER_ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH
SUPER_ADMIN_EMAIL=admin@yourdomain.ru

# ── База данных ─────────────────────────────────────────────
POSTGRES_USER=seodirect
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=seodirect
# DATABASE_URL подставляется автоматически docker-compose

# ── Безопасность ────────────────────────────────────────────
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ── JWT настройки ───────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_TOKEN_REMEMBER_DAYS=90

# ── Rate limiting ───────────────────────────────────────────
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# ── Приложение ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173

# ── Парсер сайтов ───────────────────────────────────────────
CRAWL_DELAY_MS_DEFAULT=1000
CRAWL_TIMEOUT_SECONDS=10
CRAWL_MAX_PAGES=500
CRAWL_USER_AGENT=SEODirectBot/1.0 (internal)
CRAWL_RESPECT_ROBOTS=true

# ── API ключи (можно задать здесь или через веб-интерфейс) ──
ANTHROPIC_API_KEY=
WORDSTAT_OAUTH_TOKEN=
TOPVISOR_API_KEY=
METRIKA_OAUTH_TOKEN=
DIRECT_OAUTH_TOKEN=
DIRECT_CLIENT_LOGIN=
